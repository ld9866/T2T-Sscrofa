#!/bin/bash

###############################################################################
# T2T Genome Functional Annotation & Repeat Feature Characterization Pipeline
#
# Project: Tabasco Pig Genome (T2T)
# Author: Lidong
# Date: 2026-03-09
# Version: 1.0
#
# Description:
#   This pipeline integrates Egapx annotation, primary transcript extraction,
#   segmental duplication (SD) analysis, rDNA identification, and 
#   comprehensive centromere mapping (quarTeT, RepCent, HiCAT).
###############################################################################

# =============================================================================
# 1. Global Configurations & Environment
# =============================================================================
# Paths to tools
EGAPX_PY="/path/to/egapx/ui/egapx.py"
QUARTET_PY="/home/lidong/Software/quarTeT-1.2.5/quartet.py"
HICAT_PY="/home/lidong/Software/HiCAT-master/HiCAT.py"
GENOME_EXTRACT_PY="genome_gtf_long_cds.py"

# Input Files
GENOME_FA="tabasco.t2t.fa"
SOFTMASK_FA="tabasco.softmask.fa"
HIC_CONTACTS="merged_nodups.rechr.txt"
HIFI_READS="tabasco.hifi.fastq.gz"
ONT_READS="tabasco.ont.fastq.gz"
CONFIG_YAML="example.RNA.Protein.yaml"
CEN_TEMPLATE="pig.cen.fasta"

# Metadata
PREFIX="tabasco"
THREADS=128
HICAT_THREADS=32

# =============================================================================
# 2. TASK CONTROL (Set to 1 to run, 0 to skip)
# =============================================================================
RUN_EGAPX=1
RUN_REPEATS=1
RUN_CENTROMERE=1

# =============================================================================
# 3. Phase I: Genome Functional Annotation (Egapx)
# =============================================================================
if [ $RUN_EGAPX -eq 1 ]; then
    echo "[$(date)] STAGE 1: Running Egapx Annotation..."
    
    # Run Egapx via Singularity
    python3 ${EGAPX_PY} ${CONFIG_YAML} \
        -e singularity -w ${PREFIX}.egapx_work -o ${PREFIX}.egapx_out -lc ./local_cache
    
    # Refine GFF and Extract Protein Coding Genes
    ANNOTATION_GFF="${PREFIX}.egapx_out/complete.genomic.gff"
    
    echo "[$(date)] Filtering Protein-Coding Genes..."
    awk '$3=="gene" && /gene_biotype=protein_coding/ {print $1"\t"$4"\t"$5"\t"$7}' \
        ${ANNOTATION_GFF} > ${PREFIX}.protein_genes.bed
    
    # Select Longest CDS/Primary Transcripts
    echo "[$(date)] Extracting primary transcripts (Longest CDS)..."
    python3 ${GENOME_EXTRACT_PY} ${GENOME_FA} ${ANNOTATION_GFF}
    mv out1.fa ${PREFIX}.longest_protein.fasta
fi

# =============================================================================
# 4. Phase II: Repeat Elements Analysis (SD & rDNA)
# =============================================================================
if [ $RUN_REPEATS -eq 1 ]; then
    echo "[$(date)] STAGE 2: Analyzing Segmental Duplications & rDNA..."
    
    # SD analysis with BISER
    biser -o ${PREFIX}.SD_ann -t 8 ${SOFTMASK_FA} --gc-heap 10G
    
    # rDNA analysis with Barrnap
    barrnap --kingdom euk --threads ${THREADS} \
        --outseq ${PREFIX}.rDNA.fa ${GENOME_FA} > ${PREFIX}.rDNA.gff
fi

# =============================================================================
# 5. Phase III: Multi-Method Centromere Mapping
# =============================================================================
if [ $RUN_CENTROMERE -eq 1 ]; then
    echo "[$(date)] STAGE 3: Centromere Identification..."

    # 5a. CentroMiner (quarTeT)
    python3 ${QUARTET_PY} CentroMiner -i ${GENOME_FA} -t ${THREADS} -p ${PREFIX}.cen &

    # 5b. RepCent (Centromics) - Parallelizing HiFi and ONT
    centromics -l ${HIFI_READS} -g ${GENOME_FA} -pre hifihic \
        -hic ${HIC_CONTACTS} -outdir ./centromics_hifihic -ncpu 64 &>hifihic.log &
    
    centromics -l ${ONT_READS} -g ${GENOME_FA} -pre onthic \
        -hic ${HIC_CONTACTS} -outdir ./onthic -ncpu 64 &>onthic.log &

    # 5c. HiCAT (Chromosome-wise Satellite Annotation)
    echo "[$(date)] Running HiCAT satellite annotation..."
    CHRS=( {1..18} X )
    for chr in "${CHRS[@]}"; do
        if [ -f "chr${chr}.fa" ]; then
            python3 ${HICAT_PY} -i chr${chr}.fa -t ${CEN_TEMPLATE} -th ${HICAT_THREADS} -o out_hicat_chr${chr} &
        fi
    done

    wait # Ensure all background centromere tasks finish
fi

# =============================================================================
# 6. Pipeline Completion
# =============================================================================
echo "-------------------------------------------------------"
echo "T2T Annotation & Repeat Analysis Pipeline Completed!"
echo "Timestamp: $(date)"
echo "Principal Results:"
echo " - Proteins: ${PREFIX}.longest_protein.fasta"
echo " - SD: ${PREFIX}.SD_ann/"
echo " - Centromere: Check HiCAT and Centromics outputs"
echo "-------------------------------------------------------"
