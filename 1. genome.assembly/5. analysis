#!/bin/bash

###############################################################################
# Genomic Repeat & Multicopy Element Analysis Pipeline
#
# Author: Lidong
# Date: 2026-03-09
# Description:
#   1. Identification of Segmental Duplications (SD) using BISER.
#   2. Prediction and extraction of ribosomal DNA (rDNA) using Barrnap.
#   3. Structural characterization of high-copy elements for T2T assembly.
###############################################################################

# =============================================================================
# 1. Configuration & Input Setup
# =============================================================================
# Software & Tools
BISER="biser"
BARRNAP="barrnap"

# Input Files
REF_FASTA="tabasco.pig.fa"
SOFTMASK_FASTA="tabasco.softmask.fa" # Typically generated by RepeatMasker

# Output Prefix & Resources
PREFIX="tabasco.pig"
THREADS=128
GC_HEAP="10G"

# =============================================================================
# 2. Segmental Duplication (SD) Discovery
# =============================================================================
echo "[$(date)] Running BISER for Segmental Duplication (SD) detection..."

# Note: Using softmasked fasta is recommended to speed up SD alignment
${BISER} \
    -o ${PREFIX}.SD_annotations \
    -t 8 \
    --gc-heap ${GC_HEAP} \
    ${SOFTMASK_FASTA}

# =============================================================================
# 3. Ribosomal DNA (rDNA) Identification
# =============================================================================
echo "[$(date)] Starting Barrnap for rDNA locus prediction..."

# Kingdom: euk (Eukaryotes)
${BARRNAP} \
    --kingdom euk \
    --threads ${THREADS} \
    --outseq ${PREFIX}.rDNA.fa \
    ${REF_FASTA} > ${PREFIX}.rDNA.gff

# Optional: Generate a summary of identified rDNA types (5S, 18S, 28S, etc.)
echo "[$(date)] rDNA search complete. Summary of detected loci:"
grep -v "#" ${PREFIX}.rDNA.gff | cut -f 9 | cut -d ";" -f 1 | sort | uniq -c

# =============================================================================
# 4. Final Summary
# =============================================================================
echo "-------------------------------------------------------"
echo "Repeat Analysis Pipeline Finished at $(date)"
echo "SD Output: ${PREFIX}.SD_annotations/"
echo "rDNA Output: ${PREFIX}.rDNA.gff and ${PREFIX}.rDNA.fa"
echo "-------------------------------------------------------"
