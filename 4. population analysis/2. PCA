#!/bin/bash

############################################################
# Population Structure Analysis Pipeline (PCA)
#
# Author: Lidong
#
# Description:
# This pipeline performs population structure analysis
# using SNP genotype data. The workflow converts VCF
# files into PLINK format, applies SNP quality control,
# performs LD pruning, removes outgroup individuals,
# and calculates principal components for population
# structure inference.
#
# Workflow:
#   1. Convert VCF to PLINK format
#   2. SNP quality control filtering
#   3. LD pruning
#   4. Calculate genetic distance matrix
#   5. Remove outgroup individuals
#   6. Perform principal component analysis (PCA)
#
# Requirements:
#   PLINK
#
# Input:
#   Pig.snps.filtered.simple.M2.vcf.gz
#
# Output:
#   PCA eigenvectors and eigenvalues
############################################################


# -----------------------------
# Software paths
# -----------------------------
PLINK=plink


# -----------------------------
# Input VCF file
# -----------------------------
VCF=Pig.snps.filtered.simple.M2.vcf.gz


# -----------------------------
# Output prefix
# -----------------------------
PREFIX=1303.snp


############################################################
# Step 1: Convert VCF to PLINK format
############################################################
$PLINK \
--vcf ${VCF} \
--make-bed \
--out ${PREFIX}


############################################################
# Step 2: SNP quality control
# Remove SNPs with high missing rate and low MAF
############################################################
$PLINK \
--bfile ${PREFIX} \
--geno 0.1 \
--maf 0.01 \
--make-bed \
--out ${PREFIX}.qc


############################################################
# Step 3: LD pruning
############################################################
$PLINK \
--bfile ${PREFIX}.qc \
--indep-pairwise 1000 1000 0.5 \
--out ${PREFIX}.qc.ld


$PLINK \
--bfile ${PREFIX}.qc \
--extract ${PREFIX}.qc.ld.prune.in \
--make-bed \
--out ${PREFIX}.qc.ld


############################################################
# Step 4: Calculate genetic distance matrix
############################################################
$PLINK \
--bfile ${PREFIX}.qc.ld \
--chr-set 18 \
--distance-matrix \
--out ${PREFIX}.qc.ld


############################################################
# Step 5: Remove outgroup individuals
############################################################
$PLINK \
--bfile ${PREFIX}.qc.ld \
--remove remove.list \
--make-bed \
--out 1298.snp.qc.ld


############################################################
# Step 6: Principal Component Analysis (PCA)
############################################################
$PLINK \
--bfile 1298.snp.qc.ld \
--pca 10 \
--out 1298.snp.qc.ld


echo "========================================="
echo " PCA analysis completed"
echo " Output files:"
echo " 1298.snp.qc.ld.eigenvec"
echo " 1298.snp.qc.ld.eigenval"
echo "========================================="
