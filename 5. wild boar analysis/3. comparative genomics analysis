#!/usr/bin/env bash
###############################################################################
# Script: species_divergence_time_pipeline.sh
# Author: Your Name
# Date: 2026-03-09
#
# Description:
# Pipeline for estimating species divergence time using:
#   1. OrthoFinder (single-copy ortholog detection)
#   2. MUSCLE (multiple sequence alignment)
#   3. Gblocks (alignment trimming)
#   4. seqkit (sequence processing)
#   5. PAML mcmctree (divergence time estimation)
#
# Requirements:
#   OrthoFinder, MUSCLE, Gblocks, seqkit, PAML
#
###############################################################################

set -euo pipefail

############################
# Global parameters
############################

THREADS=10

ORTHOFINDER_BIN="OrthoFinder_source/orthofinder.py"
ORTHO_INPUT="./orthofinder_input"

ALIGN_DIR="aligned_sequences"
PHY_FILE="all.rename.phy"

PAML_ENV="paml"

###############################################################################
# Step 1: Identify single-copy orthologs (OrthoFinder)
###############################################################################

echo "===== Step 1: Running OrthoFinder ====="

python ${ORTHOFINDER_BIN} \
    -t ${THREADS} \
    -a 4 \
    -f ${ORTHO_INPUT}

echo "OrthoFinder completed."

###############################################################################
# Step 2: Multiple sequence alignment (MUSCLE)
###############################################################################

echo "===== Step 2: Multiple sequence alignment ====="

mkdir -p ${ALIGN_DIR}

for i in *.fa
do

    echo "Aligning ${i}"

    muscle \
        -align ${i} \
        -output ${i}.aln

    # Trim alignment
    Gblocks ${i}.aln \
        -b4=5 \
        -b5=h \
        -t=p \
        -e=.gblocks

    # Sort sequences
    seqkit sort ${i}.aln-gb > ${i}.sorted

    # Remove line wrapping
    seqkit seq ${i}.sorted -w 0 > ${ALIGN_DIR}/${i}.fasta

done

echo "Alignment and trimming completed."

###############################################################################
# Step 3: Concatenate ortholog alignments
###############################################################################

echo "===== Step 3: Concatenating alignments ====="

cd ${ALIGN_DIR}

# Increase open file limit (optional for large datasets)
ulimit -n 102400

# Merge sequences
paste -d " " *.fasta > all.fa

# Remove spaces
sed -i "s/ //g" all.fa

# Convert FASTA to PHYLIP
python3 ../Fa2phy.py \
    -i all.fa \
    -o ${PHY_FILE}

echo "Concatenated alignment generated."

###############################################################################
# Step 4: Fossil calibration tree
###############################################################################

echo "===== Step 4: Fossil calibration ====="

echo "Please prepare a fossil-calibrated tree (tree.txt)"
echo "Sources: TimeTree or published phylogenetic studies."

###############################################################################
# Step 5: Divergence time estimation (PAML mcmctree)
###############################################################################

echo "===== Step 5: Running mcmctree ====="

conda activate ${PAML_ENV}

# First run of mcmctree (generate temporary files)
mcmctree mcmctree.ctl

###############################################################################
# Step 6: Estimate Hessian matrix (codeml)
###############################################################################

echo "===== Step 6: Running codeml ====="

cat > tmp0001.ctl <<EOF
seqfile = tmp0001.txt
treefile = tmp0001.trees
outfile = tmp0001.out
noisy = 3
seqtype = 2
model = 2
aaRatefile = wag.dat
fix_alpha = 0
alpha = .5
ncatG = 4
Small_Diff = 0.1e-6
getSE = 2
method = 1
EOF

codeml tmp0001.ctl

# Rename output for mcmctree
mv rst2 in.BV

###############################################################################
# Step 7: Final mcmctree run
###############################################################################

echo "===== Step 7: Final divergence time estimation ====="

echo "Remember to set 'usedata = 2' in mcmctree.ctl"

mcmctree mcmctree.ctl

###############################################################################
# Pipeline finished
###############################################################################

echo "===== Species divergence time estimation completed ====="
