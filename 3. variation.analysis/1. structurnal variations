#!/bin/bash

############################################################
# Structural Variant Detection Pipeline
#
# Author: Lidong
#
# Description:
# This pipeline performs structural variant (SV) detection
# from long-read sequencing data using:
#
#   1. minimap2  : long-read alignment
#   2. samtools  : BAM sorting and indexing
#   3. Sniffles2 : structural variant detection
#
# Supported sequencing platforms:
#   - PacBio HiFi
#   - Oxford Nanopore (ONT)
#   - PacBio CLR
#
# Workflow:
#   Step 1. Align reads to reference genome
#   Step 2. Sort and index BAM files
#   Step 3. Generate per-sample SNF files
#   Step 4. Merge SNF files to multi-sample VCF
#   Step 5. (Optional) Genotype known SVs
#
# Requirements:
#   minimap2  >= 2.24
#   samtools  >= 1.15
#   sniffles2 >= 2.0
#
# Input:
#   reference genome (FASTA)
#   long-read FASTQ files
#
# Output:
#   Sorted BAM files
#   SNF files
#   Multi-sample SV VCF
############################################################


# -----------------------------
# Software paths
# -----------------------------
MINIMAP2=minimap2
SAMTOOLS=samtools
SNIFFLES=sniffles


# -----------------------------
# Input files
# -----------------------------
REF=reference.fa

HIFI_READS=sample.hifi.fastq.gz
ONT_READS=sample.ont.fastq.gz
CLR_READS=sample.clr.fastq.gz


# -----------------------------
# Output prefix
# -----------------------------
HIFI_PREFIX=sample.hifi
ONT_PREFIX=sample.ont
CLR_PREFIX=sample.clr


# -----------------------------
# Thread settings
# -----------------------------
THREADS=30
SORT_THREADS=4
SORT_MEM=4G


############################################################
# Step 1: Align PacBio HiFi reads
############################################################
$MINIMAP2 \
-t ${THREADS} \
-ax map-hifi \
${REF} \
${HIFI_READS} \
| $SAMTOOLS sort \
-m ${SORT_MEM} \
-@ ${SORT_THREADS} \
-o ${HIFI_PREFIX}.bam

$SAMTOOLS index ${HIFI_PREFIX}.bam


############################################################
# Step 2: Align ONT reads
############################################################
$MINIMAP2 \
-t ${THREADS} \
-ax map-ont \
${REF} \
${ONT_READS} \
| $SAMTOOLS sort \
-m ${SORT_MEM} \
-@ ${SORT_THREADS} \
-o ${ONT_PREFIX}.bam

$SAMTOOLS index ${ONT_PREFIX}.bam


############################################################
# Step 3: Align PacBio CLR reads
############################################################
$MINIMAP2 \
-t ${THREADS} \
-ax map-pb \
${REF} \
${CLR_READS} \
| $SAMTOOLS sort \
-m ${SORT_MEM} \
-@ ${SORT_THREADS} \
-o ${CLR_PREFIX}.bam

$SAMTOOLS index ${CLR_PREFIX}.bam


############################################################
# Step 4: Generate SNF files (per-sample SV detection)
############################################################
$SNIFFLES \
--input ${HIFI_PREFIX}.bam \
--snf ${HIFI_PREFIX}.snf

$SNIFFLES \
--input ${ONT_PREFIX}.bam \
--snf ${ONT_PREFIX}.snf

$SNIFFLES \
--input ${CLR_PREFIX}.bam \
--snf ${CLR_PREFIX}.snf


############################################################
# Step 5: Merge SNF files into multi-sample VCF
############################################################
$SNIFFLES \
--input ${HIFI_PREFIX}.snf ${ONT_PREFIX}.snf ${CLR_PREFIX}.snf \
--vcf multisample.sv.vcf


############################################################
# Step 6 (Optional): Genotype known SVs
############################################################
# Example: genotype known structural variants in HiFi sample
# known_svs.vcf should contain previously identified SVs

#$SNIFFLES \
#--input ${HIFI_PREFIX}.bam \
#--genotype-vcf known_svs.vcf \
#--vcf ${HIFI_PREFIX}.genotyped.vcf


echo "======================================="
echo " Structural Variant Detection Completed"
echo " Output file: multisample.sv.vcf"
echo "======================================="
